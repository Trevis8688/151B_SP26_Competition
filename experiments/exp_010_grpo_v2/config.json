{
  "_comment": "Training hyperparams for exp_010 GRPO v2. NOT a Kaggle inference config — the inference config (model_id pointing at the trained HF repo) will be added after training completes.",
  "base_model": "Qwen/Qwen3-4B-Thinking-2507",
  "output_repo": "TrevorDuong/qwen3-4b-thinking-grpo-v2",
  "curriculum_file": "sweet_spot_ids.json",
  "num_curriculum_prompts": 196,
  "training": {
    "epochs": 2,
    "learning_rate": 1e-5,
    "beta": 0.02,
    "num_generations": 4,
    "max_prompt_length": 1024,
    "max_completion_length": 6144,
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 4,
    "lora_r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.0,
    "temperature_train": 1.0,
    "save_strategy": "steps",
    "save_steps": 25,
    "save_total_limit": 3
  },
  "reward": {
    "correctness_weight": 1.0,
    "format_weights": {
      "has_think_close": 0.05,
      "has_boxed": 0.10,
      "boxed_post_think": 0.05,
      "single_boxed_post_think": 0.025
    },
    "_note": "Format reward max = 0.225. Granular scoring ensures variance even when correctness is uniform across the 4 stochastic rollouts."
  }
}
